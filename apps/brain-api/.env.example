# Copy to .env for local dev. In production, inject these via your
# secrets manager (AWS Secrets Manager, Vault, GCP Secret Manager) as
# real environment variables — do not commit a populated .env.

ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-5
CLAUDE_MAX_TOKENS=1024

# Local dev default. Production: postgresql+psycopg2://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./ai_body_os.db

HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:5173

COLLISION_STOP_DISTANCE_M=0.4
BALANCE_TILT_LIMIT_DEG=35
CLAUDE_REASONING_INTERVAL_TICKS=10
